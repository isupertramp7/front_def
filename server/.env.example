# Base de datos PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/marcacion_go?schema=public"

# Servidor
PORT=4000
NODE_ENV=development

# JWT
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_seguro_minimo_32_chars
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=otro_secreto_diferente_para_refresh_token
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CLIENT_URL=http://localhost:5173

# AWS (para producción)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=marcacion-go-reportes
